DATABASE_URL="postgresql://user:password@localhost:55432/grupiah_db?schema=public"

# --- TELEGRAM BOT TOKENS ---
BOT_TOKEN="your_telegram_bot_token"
ADMIN_BOT_TOKEN="your_admin_notification_bot_token"

# --- REQUIRED FOR PUBLIC DEPLOYMENT ---
NODE_ENV="production"
PORT=53000

# --- ADMIN WEB DASHBOARD SECURITY ---
# Password superadmin untuk masuk ke admin.grupiah.online
ADMIN_WEB_PASSWORD="GANTI_DENGAN_PASSWORD_SULIT"
# Random string rahasia untuk enkripsi sesi login (Gunakan minimal 32 karakter)
JWT_SECRET="GANTI_DENGAN_RANDOM_STRING_PANJANG_UNTUK_PRODUKSI"

# --- THIRD-PARTY APIS ---
OGADS_API_KEY="your_ogads_key"
PROXYCHECK_API_KEY="your_proxycheck_key"
XENDIT_API_KEY="your_xendit_key"
ADBLUEMEDIA_USER_ID="your_adblue_id"
ADBLUEMEDIA_API_KEY="your_adblue_key"

# --- BROADCAST & AI SETTINGS ---
# Google Gemini API Key for content generation
GEMINI_API_KEY="your_gemini_api_key"
# Target Telegram Channel ID to Broadcast (e.g., @grupiah_official or -100123456)
CHANNEL_ID="@grupiah_official"

# Target Private Channel ID for File Storage (e.g., -10098765432)
# Bot Utama (BOT_TOKEN) harus menjadi Admin di channel ini juga agar bisa menyimpan gambar bukti tugas.
DATABASE_CHANNEL_ID="-100_YOUR_DATABASE_CHANNEL"
