FROM node:20-alpine

RUN npm install -g serve

WORKDIR /app

# Copy ENTIRE monorepo (filtered by .dockerignore)
COPY . .

# Install ALL dependencies
RUN npm install

# Build Vite Landing Page
RUN npx turbo run build --filter=tma-landing

EXPOSE 53004

CMD ["serve", "-s", "apps/tma-landing/dist", "-p", "53004"]
