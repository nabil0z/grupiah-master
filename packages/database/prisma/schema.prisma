generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(uuid())
  telegramId      BigInt         @unique
  username        String?
  firstName       String?
  lastName        String?
  role            UserRole       @default(USER) // Membedakan antara USER biasa, ADMIN, SUPER_ADMIN
  isBanned        Boolean        @default(false)
  isMarketingAcc  Boolean        @default(false) // Flag khusus Bypass Approval Marketing
  isFake          Boolean        @default(false) // Data marketing/influencer palsu
  wallet          Wallet?
  activeBoost     UserBoost?     // Relasi khusus Boost berbayar via Telegram Stars
  referralCode    String         @unique
  referredById    String?
  referredBy      User?          @relation("UserReferrals", fields: [referredById], references: [id])
  referrals       User[]         @relation("UserReferrals")
  isReferralActive Boolean       @default(false) // Akan menjadi True & Bonus cair JIKA invitee menyelesaikan 1 Task API
  dailyStreak     Int            @default(0)
  lastLogin       DateTime?
  badges          UserBadge[]
  userTasks       UserTask[]
  withdrawals     Withdrawal[]
  offerClicks     UserOfferClick[]
  creatorStatus         String         @default("NONE") // NONE | PENDING | APPROVED | REJECTED
  creatorChannels       String?        // JSON: [{"platform":"TIKTOK","channel":"@budi"}]
  wdMode                String?        // AUTO | MANUAL (null = ikut global admin)
  marketingDelaySeconds Int            @default(30) // Delay auto-approve task (detik)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Wallet {
  id        String           @id @default(uuid())
  userId    String           @unique
  user      User             @relation(fields: [userId], references: [id])
  balance   Decimal          @default(0.0)
  mutations WalletMutation[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model WalletMutation {
  id          String       @id @default(uuid())
  walletId    String
  wallet      Wallet       @relation(fields: [walletId], references: [id])
  amount      Decimal      // Negatif jika withdraw, positif jika earn
  type        MutationType // EARN, WITHDRAW, REFERRAL_BONUS, ADMIN_ADJUSTMENT
  description String
  createdAt   DateTime     @default(now())
}

enum MutationType {
  EARN
  WITHDRAW
  REFERRAL_BONUS
  ADMIN_ADJUSTMENT
}

model PlatformConfig {
  id              String   @id @default(uuid())
  key             String   @unique // e.g., 'GLOBAL_REWARD_MULTIPLIER'
  value           String   // e.g., '10' (disimpan sebagai string, dikonversi sesuai kebutuhan)
  updatedBy       String?  // Admin ID
  updatedAt       DateTime @updatedAt
}

model Task {
  id          String       @id @default(uuid())
  provider    String       // 'CUSTOM', 'OGADS', 'ADBLUEMEDIA'
  externalId  String?      // ID unik dari provider eksternal
  title       String
  description String
  instructions String?     // Panduan langkah-langkah tugas (Opsional)
  logoUrl     String?      // URL gambar icon/logo
  link        String?      // Link URL eksternal menuju task
  reward      Decimal
  type        TaskType     // AUTO, MANUAL
  isActive    Boolean      @default(true)
  isFake      Boolean      @default(false) // Marketing/influencer fake task
  userTasks   UserTask[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum TaskType {
  AUTO
  MANUAL
}

model UserTask {
  id        String     @id @default(uuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  taskId    String
  task      Task       @relation(fields: [taskId], references: [id])
  status    TaskStatus // PENDING, APPROVED, REJECTED
  proofUrl  String?    // Link S3/R2 bukti screenshot (khusus MANUAL)
  proofText String?    // Teks tambahan, seperti username follower
  reward    Decimal?   // Menyimpan nilai reward statis saat task diambil
  isFake    Boolean    @default(false) // Marketing/influencer fake record
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([userId, taskId]) // Mencegah 1 user kerjakan 1 task berulang kali secara double submit
}

enum TaskStatus {
  PENDING
  APPROVED
  REJECTED
}

// Model untuk Analytics & Sorting Offers
model OfferScore {
  id          String   @id @default(uuid())
  provider    String   // 'CUSTOM', 'OGADS', 'ADBLUEMEDIA'
  externalId  String   // ID dari provider atau ID Task internal
  clicks      Int      @default(0)
  completions Int      @default(0)
  revenue     Decimal  @default(0) // Raw USD revenue from provider
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([provider, externalId])
}

model OfferCompletion {
  id          String   @id @default(uuid())
  provider    String
  externalId  String
  userId      String
  revenue     Decimal  @default(0) // Raw USD revenue from provider
  createdAt   DateTime @default(now())
  
  @@unique([provider, externalId, userId]) // Mencegah postback ganda
}

model UserOfferClick {
  id          String   @id @default(uuid())
  userId      String
  provider    String
  externalId  String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, provider, externalId])
}

model Withdrawal {
  id              String           @id @default(uuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  amount          Decimal
  method          WithdrawalMethod
  accountInfo     String           // JSON berisi no_rekening, bank, dll. (disarankan terenkripsi)
  status          WithdrawStatus   @default(PENDING)
  isFake          Boolean          @default(false) // Marketing/influencer fake WD
  processedBy     String?          // ID Admin pengekseskusi
  autoApproveAt   DateTime?        // If set, cron will auto-approve at this time
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

enum WithdrawalMethod {
  BANK_TRANSFER
  DANA
  OVO
  GOPAY
}

enum WithdrawStatus {
  PENDING
  PROCESSING
  PAID
  REJECTED
}

// History Penarikan Saldo Palsu untuk Social Proof di Frontend
model FakeWithdrawHistory {
  id              String   @id @default(uuid())
  maskedUsername  String   @default("user****") // e.g. "Budi*****", "0812****"
  amount          Decimal
  method          String   // "DANA", "GOPAY", dll
  createdAt       DateTime @default(now())
}

// Fitur Boost Pembayaran Telegram Stars
model UserBoost {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  multiplierRate  Decimal  // misal 1.5, 2.0 (Pengali dari harga admin)
  expiresAt       DateTime // Masa aktif boost (misal 24 jam)
  purchasedStar   Int      // Berapa Stars yang dibakar user
  createdAt       DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?  // Admin ID / User ID
  actorType  String   // 'ADMIN' atau 'USER'
  action     String   // e.g., "WITHDRAWAL_APPROVED", "USER_BANNED"
  entityType String   // e.g., "Withdrawal", "UserTask"
  entityId   String
  changes    String?    // Snapshot before & after state changes
  ipAddress  String?
  createdAt  DateTime @default(now())
}

model Badge {
  id          String      @id @default(uuid())
  name        String
  description String
  iconUrl     String
  condition   Int         // Minimal kondisi pencapaian (e.g. 100 task total)
  users       UserBadge[]
}

model UserBadge {
  userId  String
  badgeId String
  user    User   @relation(fields: [userId], references: [id])
  badge   Badge  @relation(fields: [badgeId], references: [id])

  @@id([userId, badgeId])
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}
