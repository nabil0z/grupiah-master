FROM node:20-alpine

RUN npm install -g serve

WORKDIR /app

# Copy root monorepo config
COPY package.json package-lock.json turbo.json ./

# Copy packages (shared deps)
COPY packages ./packages

# Copy the tma-client app
COPY apps/tma-client ./apps/tma-client

# Install all dependencies
RUN npm install

# Build Vite
RUN npm run build --workspace=tma-client

EXPOSE 53002

CMD ["serve", "-s", "apps/tma-client/dist", "-p", "53002"]
