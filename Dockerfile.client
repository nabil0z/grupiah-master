FROM node:20-alpine

RUN npm install -g serve

WORKDIR /app

# Copy ENTIRE monorepo (filtered by .dockerignore)
COPY . .

# Install ALL dependencies
RUN npm install

# Build Vite TMA Client
RUN npx turbo run build --filter=tma-client

EXPOSE 53002

CMD ["serve", "-s", "apps/tma-client/dist", "-p", "53002"]
